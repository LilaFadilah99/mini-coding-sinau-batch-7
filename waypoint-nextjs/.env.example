# Waypoint Next.js — Environment Variables Template
# Copy file ini jadi .env.local dan isi nilai-nya

# Google Gemini API Key
# Dapatkan di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Supabase Project URL & Publishable Key
# Dapatkan di: Supabase dashboard → Settings → API
# Format key baru Supabase: sb_publishable_xxxxx (atau anon JWT lama eyJ...)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
